# MongoDB connection
MONGODB_URI=mongodb://admin:password@localhost:27017/crm?authSource=admin

# NextAuth config
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Set to: gemini (default) | groq
AI_PROVIDER=gemini

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_key_here

# Groq (https://console.groq.com/keys) — ultra-fast inference, free tier available
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile